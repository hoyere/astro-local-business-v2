---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/sections/Hero.astro';
import Contact from '@components/sections/Contact.astro';
import { siteConfig } from '../site.config';
---

<BaseLayout
  title={`Contact Us | ${siteConfig.name}`}
  description="Schedule a pool assessment or ask about our maintenance programs. We respond within one business day."
>
  <Hero
    title="Contact Us"
    subtitle="Get In Touch"
    description="Schedule your free pool assessment, ask about our maintenance programs, or request emergency service."
    variant="centered"
  />

  <Contact />
</BaseLayout>
