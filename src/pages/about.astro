---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/sections/Hero.astro';
import Team from '@components/sections/Team.astro';
import Testimonials from '@components/sections/Testimonials.astro';
import CTA from '@components/sections/CTA.astro';
import Container from '@components/common/Container.astro';
import { siteConfig } from '../site.config';
---

<BaseLayout
  title={`About Us | ${siteConfig.name}`}
  description="Learn how GrowthAutomations Pool Systems brings process engineering to residential pool care."
>
  <Hero
    title="About Us"
    subtitle="Our Story"
    description="We started with a simple question: why does pool maintenance still rely on guesswork?"
    variant="centered"
  />

  <section class="section">
    <Container>
      <div class="about-content">
        <div class="about-story">
          <h2>Our Story</h2>
          <p>
            GrowthAutomations Pool Systems started when our founder, Wade Chlorston, noticed
            that the same operational rigor he applied to logistics automation was completely
            absent from pool maintenance. Technicians were eyeballing chemical doses, skipping
            inspection steps, and leaving homeowners to discover problems after the damage was done.
          </p>
          <p>
            We built a different kind of pool service company. Every visit follows a documented
            protocol. Every chemical addition is calculated, not estimated. Every equipment
            reading is benchmarked against manufacturer specs. The result: consistent water
            quality, fewer emergency repairs, and pools that just work.
          </p>
        </div>

        <div class="values-grid">
          <div class="value-card">
            <h3>Our Mission</h3>
            <p>
              To bring systematic precision to residential pool care, eliminating guesswork
              and delivering measurable, repeatable results for every pool we service.
            </p>
          </div>
          <div class="value-card">
            <h3>Our Vision</h3>
            <p>
              A world where pool owners never have to worry about water quality or equipment
              failures — because the systems catch everything first.
            </p>
          </div>
          <div class="value-card">
            <h3>Our Values</h3>
            <p>
              Precision over shortcuts. Data over gut feel. Transparency over hand-waving.
              We document everything and share what we find.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <Team />

  <Testimonials
    title="What Pool Owners Say"
    subtitle="Results speak louder than promises"
  />

  <CTA
    title="Want to See the Difference?"
    description="Schedule a free pool assessment. We'll benchmark your equipment and show you what systematic care looks like."
    primaryCta={{ text: "Get Started", href: "/contact" }}
  />
</BaseLayout>

<style>
  .about-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .about-story {
    margin-bottom: 3rem;
  }

  .about-story h2 {
    margin-bottom: 1.5rem;
  }

  .about-story p {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .about-story p:last-child {
    margin-bottom: 0;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .values-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .value-card {
    padding: 1.5rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .value-card h3 {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }

  .value-card p {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
  }
</style>
