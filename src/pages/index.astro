---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/sections/Hero.astro';
import Services from '@components/sections/Services.astro';
import About from '@components/sections/About.astro';
import Testimonials from '@components/sections/Testimonials.astro';
import CTA from '@components/sections/CTA.astro';
import { siteConfig } from '../site.config';
---

<BaseLayout>
  <Hero
    title="Crystal-Clear Water, Precision-Engineered Maintenance"
    subtitle="GrowthAutomations Pool Systems"
    description="We bring documented processes and data-driven precision to pool care. Every visit follows a 27-point protocol — no variance, no guesswork, no green water."
    primaryCta={{ text: "Schedule Service", href: "/contact" }}
    secondaryCta={{ text: "Our Services", href: "/services" }}
    variant="centered"
  />

  <Services />

  <About />

  <Testimonials />

  <CTA
    title="Ready for Systematic Pool Care?"
    description="Get a free assessment of your pool's current condition. We'll benchmark your equipment and recommend the right maintenance plan."
    primaryCta={{ text: "Get a Free Assessment", href: "/contact" }}
    secondaryCta={{ text: "Call Now", href: `tel:${siteConfig.contact.phone.replace(/[^\d+]/g, '')}` }}
  />
</BaseLayout>
